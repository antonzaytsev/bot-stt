#!/usr/bin/env bash
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}==> ${1}${NC}"; }
warn()  { echo -e "${YELLOW}==> ${1}${NC}"; }
done_() { echo -e "${GREEN}==> ${1}${NC}"; }

prompt() {
  local var_name="$1" prompt_text="$2" default="${3:-}"
  if [ -n "$default" ]; then
    echo -en "${CYAN}${prompt_text} [${default}]: ${NC}"
    read -r value
    eval "$var_name=\"${value:-$default}\""
  else
    while true; do
      echo -en "${CYAN}${prompt_text}: ${NC}"
      read -r value
      if [ -n "$value" ]; then
        eval "$var_name=\"$value\""
        break
      fi
      warn "This field is required."
    done
  fi
}

echo ""
echo "========================================="
echo "  bot-stt setup"
echo "========================================="
echo ""

# --- .env ---
if [ -f .env ]; then
  warn ".env already exists."
  echo -en "${CYAN}Overwrite? (y/N): ${NC}"
  read -r overwrite
  if [[ ! "$overwrite" =~ ^[Yy]$ ]]; then
    info "Keeping existing .env"
    skip_env=true
  fi
fi

if [ "${skip_env:-}" != "true" ]; then
  info "Let's configure your environment."
  echo ""

  prompt BOT_TOKEN    "Telegram bot token (from @BotFather)"
  prompt OPENAI_KEY   "OpenAI API key"
  prompt ADMIN_ID     "Your Telegram user ID (from @userinfobot)"
  prompt APP_PORT     "App port" "3000"
  prompt ENVIRONMENT  "Environment (development/production)" "development"

  WEBHOOK_SECRET=$(LC_ALL=C tr -dc 'a-zA-Z0-9' < /dev/urandom | head -c 32 || true)

  cat > .env <<ENVFILE
TELEGRAM_BOT_TOKEN=${BOT_TOKEN}
OPENAI_API_KEY=${OPENAI_KEY}
ADMIN_CHAT_ID=${ADMIN_ID}
REDIS_URL=redis://redis:6379/0
WEBHOOK_SECRET=${WEBHOOK_SECRET}
PORT=${APP_PORT}
RACK_ENV=${ENVIRONMENT}
ENVFILE

  done_ ".env created"
  echo ""
fi

# --- Docker build ---
info "Building Docker images..."
docker compose build --quiet
done_ "Docker images built"

echo ""
echo "========================================="
echo "  Setup complete!"
echo "========================================="
echo ""
info "Start the app:  docker compose up"
info "Register webhook after the app is publicly reachable:"
echo "  docker compose exec web bundle exec rake bot:set_webhook WEBHOOK_URL=https://your-domain.com/webhook"
echo ""
